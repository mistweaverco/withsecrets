{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://withsecrets.com/kuba-global.schema.json",
  "title": "Global Kuba Configuration File",
  "description": "Schema for the global kuba configuration file located at ~/.config/withsecrets/config.yaml (legacy: ~/.config/kuba/config.yaml)",
  "type": "object",
  "properties": {
    "cache": {
      "description": "Cache configuration. Can be a boolean, number (seconds), or duration string (e.g., '1d', '2w', '72h', '2y').",
      "oneOf": [
        { "type": "boolean" },
        { "type": "number" },
        { "type": "string", "pattern": "^(\\d+(?:\\.\\d+)?[smhdwy]|\\d+)$" },
        {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "ttl": {
              "oneOf": [
                { "type": "number" },
                { "type": "string", "pattern": "^(\\d+(?:\\.\\d+)?[smhdwy]|\\d+)$" }
              ]
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "defaults": {
      "description": "Optional defaults used to pre-fill CLI/TUI prompts.",
      "type": "object",
      "properties": {
        "providers": {
          "description": "Provider-specific default settings. Keys must match provider names used in kuba.yaml providers section (e.g. aws, azure, gcp).",
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "regions": {
                "description": "Default regions/locations for this provider.",
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
