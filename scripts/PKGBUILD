source_i686=("${pkgname}-${pkgver}.tar.gz::https://github.com/mistweaverco/withsecrets/releases/download/v${pkgver}/ws-linux-386")

# NOTE: Auto-generated by CI via updpkgsums
sha256sums=('AUTO_GENERATED')
